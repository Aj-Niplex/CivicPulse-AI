rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Logged in users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Hackathon MVP
    match /issues/{issueId} {
      allow read, write: if request.auth != null;
    }

    // votes subcollection
    match /issues/{issueId}/votes/{voteId} {
      allow read, write: if request.auth != null;
    }
  }
}